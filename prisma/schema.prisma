// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EnumSystemParamsModules {
  AUTH

  @@map("enum_system_params_modules")
}

enum EnumRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY

  @@map("enum_recurrence")
}

enum EnumNotificationTime {
  MIN_5
  MIN_10
  MIN_30
  HOUR_1
  HOUR_2
  DAY_1

  @@map("enum_notification_time")
}

model User {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid()) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  name         String
  username     String
  email        String  @unique
  phone        String?
  password     String
  chat_id      String? @unique
  google_id    String? @unique
  google_email String?

  user_has_permissions UsersHasPermissions[]
  tags                 Tag[]
  events               Event[]

  @@map("users")
}

model UsersHasPermissions {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  user_id       Int
  permission_id Int

  user       User        @relation(fields: [user_id], references: [id])
  permission Permissions @relation(fields: [permission_id], references: [id])

  @@map("users_has_permissions")
}

model Permissions {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  label   String
  module  String @default("Usuários")
  key     String @unique
  message String

  users_has_permissions UsersHasPermissions[]

  @@map("permissions")
}

model Tag {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  name       String
  color      String
  icon       String
  is_default Boolean @default(false)

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id])

  event_tags EventTag[]

  @@map("tags")
}

model Event {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid()) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  title       String
  description String?
  start_at    DateTime
  end_at      DateTime
  all_day     Boolean        @default(false)
  recurrence  EnumRecurrence @default(NONE)

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  event_tags       EventTag[]
  event_exceptions EventException[]
  notification     EventNotification?

  @@map("events")
}

model EventTag {
  id    Int @id @default(autoincrement())
  order Int @default(0)

  event_id Int
  tag_id   Int

  event Event @relation(fields: [event_id], references: [id])
  tag   Tag   @relation(fields: [tag_id], references: [id])

  @@map("event_tags")
}

model EventException {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  original_date   DateTime
  new_title       String?
  new_description String?
  new_start_at    DateTime?
  new_end_at      DateTime?
  new_all_day     Boolean?
  cancelled       Boolean   @default(false)

  event_id Int
  event    Event @relation(fields: [event_id], references: [id])

  @@map("event_exceptions")
}

model EventNotification {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  time    EnumNotificationTime
  enabled Boolean              @default(true)

  event_id Int   @unique
  event    Event @relation(fields: [event_id], references: [id])

  @@map("event_notifications")
}

model SystemParams {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)
  deleted    Boolean  @default(false)

  key         String                  @unique
  value       String
  module      EnumSystemParamsModules
  description String?

  @@map("system_params")
}
